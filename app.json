{
  "expo": {
    "name": "momentum-mobile-v2",
    "slug": "momentum-mobile-v2",
    "version": "1.0.0",
    "scheme": "momentum",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "main": "index.ts",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": false,
      "bundleIdentifier": "com.momentum.mobile"
    },
    "android": {
      "package": "com.momentum.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "screenOrientation": "portrait",
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-calendar",
        {
          "calendarPermission": "The app needs to access your calendar to show your events."
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "1fe4c558-61c9-4653-a838-6d32555dafbd"
      },
      "EXPO_PUBLIC_API_BASE_URL": "https://momentum-mobile-bff.onrender.com/mobile-bff",
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "586333342003-i7t3b613209bhfp4abnd8fti80t52r38.apps.googleusercontent.com"
    },
    "owner": "partpanda"
  }
}
